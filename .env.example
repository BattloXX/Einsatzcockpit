# ─── Datenbank ────────────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://einsatzleiter:PASSWORT@127.0.0.1:3306/einsatzleiter

# ─── Session / Sicherheit ─────────────────────────────────────────────
# Pflicht: min. 32 Zeichen, langer zufälliger String. Erzeugen z.B. mit:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
SESSION_MAX_AGE_SECONDS=86400
SESSION_INACTIVITY_SECONDS=28800
# PFLICHT in Produktion (DEBUG=false): true, sonst bricht der App-Start hart ab
# (validate_startup_secrets() in app/config.py). In Produktion IMMER auf true,
# da HTTPS via nginx vorausgesetzt wird.
COOKIE_SECURE=false

# ─── Reverse-Proxy (X-Forwarded-For) ──────────────────────────────────
# X-Forwarded-For/-Proto werden nur akzeptiert, wenn die Verbindung von einer
# der TRUSTED_PROXY_IPS kommt (Default: localhost, passend zu nginx auf
# demselben Host, siehe deploy/nginx-snippet.conf). Läuft die App OHNE
# vorgelagerten Proxy direkt am Netz: TRUST_PROXY_HEADERS=false setzen —
# sonst wäre die Client-IP für Rate-Limits/Audit-Logs per Header fälschbar.
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_IPS=127.0.0.1,::1

# ─── App ──────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8092
APP_BASE_URL=https://einsatzcockpit.com
# Öffentliche URL für Mail-Links (Passwort-Reset etc.). Leer = APP_BASE_URL
PUBLIC_BASE_URL=
DEBUG=false
# Testsystem-Modus: Zeigt einen deutlichen "TEST SYSTEM" Hinweis im Header und auf Ausdrucken
TEST_SYSTEM=false
# Slow-Query-Logging: Queries oberhalb dieser Schwelle (ms) als WARNING loggen
# (Logger "einsatzleiter.slow_query", auch in der Sysadmin-Log-Ansicht). 0 = aus.
SLOW_QUERY_LOG_MS=300

# ─── Redis Pub/Sub-Bus (worker-übergreifende WebSockets) ──────────────────
# PFLICHT bei mehreren Workern (gunicorn -w 2+, siehe deploy/einsatzleiter.service):
# ohne Redis erreichen Live-Broadcasts UND Gateway-Druckaufträge nur den Worker,
# der den jeweiligen Socket hält → Stationsdruck schlägt worker-abhängig fehl.
# Zusätzlich zählen Rate-Limits (Login, API, Uploads) nur mit Redis worker-
# übergreifend — ohne teilt sich das Limit NICHT, jeder Worker hat ein eigenes
# Kontingent (effektiv Limit × Workerzahl).
# Leer lassen ist nur bei -w 1 korrekt.
REDIS_URL=redis://127.0.0.1:6379/0

# ─── Web Push (VAPID) ─────────────────────────────────────────────────
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=admin@example.com

# ─── Erster Admin (nur beim ersten Start ausgewertet) ─────────────────
# Wenn BOOTSTRAP_ADMIN_PASSWORD leer ist, wird beim ersten Start ein
# zufälliges Passwort generiert und einmalig in den Log geschrieben.
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=

# ─── PDF ──────────────────────────────────────────────────────────────
PDF_LOGO_PATH=app/static/img/logo.png

# ─── SMTP / Mail (für Passwort-Reset) ─────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=einsatzleiter@feuerwehr-wolfurt.at
SMTP_STARTTLS=true
SMTP_TIMEOUT=15
PASSWORD_RESET_TTL_MIN=30

# ─── Login-Lockout ────────────────────────────────────────────────────
LOGIN_MAX_FAILED=5
LOGIN_LOCKOUT_MINUTES=15

# ─── Fernet-Verschlüsselung ───────────────────────────────────────────
# PFLICHT in Produktion (DEBUG=false): ohne eigenen Key bricht der App-Start
# hart ab (validate_startup_secrets() in app/config.py, seit 2026-07-01).
# Grund: leer würde den Datenschlüssel aus SHA256(SECRET_KEY) ableiten, wodurch
# eine spätere SECRET_KEY-Rotation gespeicherte SSO-Client-Secrets/KI-API-Keys
# unentschlüsselbar macht. Eigener Key ist außerdem unabhängig rotierbar.
# Generieren: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ─── SSO / Microsoft Entra ID ────────────────────────────────────────
# Globaler Killswitch. Verbindungsdaten (Tenant ID, Client ID, Secret)
# werden je Organisation im Tool selbst unter Admin -> SSO konfiguriert.
SSO_ENABLED=true
# MS_LOGIN_BASE_URL=https://login.microsoftonline.com  # nur für Sovereign Clouds ändern
# SSO_HTTP_TIMEOUT=10
# SSO_FLOW_MAX_AGE=600
# SSO_JWKS_CACHE_TTL=3600

# ─── In-App-Update-Mechanismus ────────────────────────────────────────
# Wenn true, muss beim ZIP-Upload der SHA256 des Releases angegeben werden
UPDATE_ZIP_REQUIRE_HASH=true

# ─── Nachschlagewerke (Gefahrgut / Rettungskarten) ────────────────────────
# Persistentes Verzeichnis fuer gesyncte Daten (ausserhalb des read-only Repos).
NACHSCHLAGEWERK_DATA_DIR=app_storage/nachschlagewerk
# Taeglicher Gefahrgut-Datensatz-Sync (03:00). false = aus (nur gebuendelter Seed).
NACHSCHLAGEWERK_SYNC_ENABLED=true
# Quelle der vollstaendigen BAM/ADR-Gefahrgut-Daten (dl-de/by-2.0). Akzeptiert eine
# direkte ;-getrennte CSV ODER ein ZIP (z. B. BAM-Download mit BAM-Gefahrgutdaten.csv +
# -status.csv; das Datenblatt wird automatisch entpackt/erkannt). Leer = Seed bleibt.
NACHSCHLAGEWERK_GEFAHRGUT_URL=
# On-demand-Quelle fuer Rettungsdatenblaetter (PDF). URL-Template mit {hersteller}
# und {modell} (urlsafe eingesetzt). Leer = kein Abruf, nur Deep-Links (Euro Rescue).
# Rechtlich: keine Massen-Spiegelung, nur Einzelabruf bei Bedarf.
NACHSCHLAGEWERK_RETTUNGSKARTEN_URL_TEMPLATE=

# ─── Datenbank-Backup + Restore-Probe ─────────────────────────────────────
# python -m app.cli backup  /  restore-test  (systemd-Timer in deploy/backup/).
# Runbook: docs/wiki/Betrieb-Backup-und-Disaster-Recovery.md
# Zielverzeichnis der Dumps (persistent; zusaetzlich Offsite spiegeln, 3-2-1-Regel).
BACKUP_DIR=app_storage/backups
# So viele der neuesten Dumps je DB/Medien behalten.
BACKUP_KEEP_DAILY=14
# Medien (app_storage) mitsichern.
BACKUP_INCLUDE_MEDIA=true
# MariaDB-Client-Binaries (ggf. absoluter Pfad).
BACKUP_DUMP_BIN=mariadb-dump
BACKUP_CLIENT_BIN=mariadb
# Wegwerf-DB der Restore-Probe (darf NIE die Produktions-DB sein). Der DB-User
# braucht CREATE/DROP darauf (siehe Runbook, Abschnitt "Restore-Probe").
BACKUP_RESTORE_TEST_DB=einsatzleiter_restore_test

# ─── Off-Site-Upload der Backups (3-2-1-Regel) ────────────────────────────
# Nach jedem `app.cli backup` automatisch an eine Gegenstelle schieben; separat
# testbar via `app.cli backup-upload`. true = aktiv.
BACKUP_REMOTE_ENABLED=false
# Protokoll: sftp | scp | rsync | ftp | ftps | rclone
#  sftp/scp/rsync = SSH (Key-Auth, sicher, empfohlen) · ftps = FTP+TLS
#  ftp = UNVERSCHLUESSELT (nur LAN!) · rclone = S3/WebDAV/Backblaze/GDrive/...
BACKUP_REMOTE_PROTOCOL=sftp
BACKUP_REMOTE_HOST=
BACKUP_REMOTE_PORT=0                 # 0 = Standard (22 bzw. 21)
BACKUP_REMOTE_USER=
BACKUP_REMOTE_PASSWORD=              # NUR fuer ftp/ftps (SSH nutzt Key)
BACKUP_REMOTE_KEY=                   # Pfad zum privaten SSH-Key (sftp/scp/rsync)
BACKUP_REMOTE_PATH=                  # Zielverzeichnis auf der Gegenstelle
# SSH-Hostkey-Pruefung: accept-new (TOFU) | yes (strikt, known_hosts) | no
BACKUP_REMOTE_SSH_STRICT=accept-new
# rclone: Remote-Name inkl. Doppelpunkt (z. B. "offsite:" oder "s3:bucket")
BACKUP_REMOTE_RCLONE_REMOTE=
# Nur die neuesten Dumps je Typ hochladen (true) oder alle im BACKUP_DIR (false)
BACKUP_REMOTE_ONLY_LATEST=true
# Binaries (ggf. absoluter Pfad)
BACKUP_REMOTE_SCP_BIN=scp
BACKUP_REMOTE_SFTP_BIN=sftp
BACKUP_REMOTE_RSYNC_BIN=rsync
BACKUP_REMOTE_RCLONE_BIN=rclone

# ─── Self-Service-Backup je Organisation ──────────────────────────────────
# Jede Org sichert ihre eigenen (tenant-gescopten) Daten selbst: Download oder
# geplanter Push an ein selbst konfiguriertes Ziel (SFTP/SCP/rsync/FTP/FTPS/rclone).
# Restore in eine neue Org ist eine system_admin-Aktion. Konfiguration je Org unter
# /admin/org-backup. Runbook: docs/wiki/Administration-Org-Datensicherung.md
# Globaler Kill-Switch (false = Modul komplett aus).
ORG_BACKUP_ENABLED=true
# Groessenlimit je Org-Archiv (Schutz vor Ueberlast; 0 = unbegrenzt).
ORG_BACKUP_MAX_BYTES=2147483648
# Intervall (Sekunden), in dem faellige geplante Org-Backups geprueft werden.
ORG_BACKUP_LOOP_INTERVAL_S=900

# ─── KI-Integration (Anthropic Claude) ───────────────────────────────────
# Aktivierung: AI_ENABLED=true + gültiger API-Key → KI-Funktionen sichtbar.
# Standardmäßig deaktiviert; bewusst pro Instanz einschalten.
ANTHROPIC_API_KEY=
AI_ENABLED=false
AI_MODEL_DEFAULT=claude-sonnet-4-6
AI_MODEL_FAST=claude-haiku-4-5-20251001
AI_MAX_TOKENS=1500
AI_TIMEOUT=20

# ─── Firebase Cloud Messaging (native Android Push) ───────────────────
# FCM_ENABLED=true aktiviert den zweiten Push-Kanal neben VAPID.
# FCM_PROJECT_ID: Firebase Project-ID (z.B. "einsatzleiter-12345")
# FCM_CREDENTIALS_PATH: Absoluter Pfad zur Service-Account-JSON ausserhalb des Repos
FCM_ENABLED=false
FCM_PROJECT_ID=
FCM_CREDENTIALS_PATH=/etc/einsatzleiter/fcm-service-account.json

# ─── Lokale Wetterstation (Davis Vantage Pro 2 / Meteobridge) ──────────
# Separate DB fuer die Zeitreihe (eigener Pool, damit Einsatz-Funktionen Vorrang
# behalten und die operative DB nicht aufgeblaeht wird). Leer = Feature deaktiviert.
WEATHER_DATABASE_URL=mysql+pymysql://einsatzleiter:PASSWORT@127.0.0.1:3306/einsatzleiter_weather
# Ingest-Endpoint (Meteobridge-Push) global aktiv
WEATHER_STATION_INGEST_ENABLED=true
# Aufbewahrungsdauer der historischen Messwerte in Tagen (taegliche Loeschung)
WEATHER_READING_RETENTION_DAYS=365
# Mindestabstand zwischen zwei akzeptierten Pushes je Station (Sekunden)
WEATHER_INGEST_MIN_INTERVAL_S=60
