[Unit]
Description=Einsatzcockpit Restore-Probe (spielt den neuesten Dump testweise ein)
After=network.target mariadb.service
Wants=mariadb.service

[Service]
Type=oneshot
User=clp-einsatz
Group=clp-einsatz
WorkingDirectory=/home/clp-einsatz/htdocs/einsatzleiter
EnvironmentFile=/home/clp-einsatz/htdocs/einsatzleiter/.env
# Der DB-Benutzer braucht CREATE/DROP auf die Wegwerf-DB
# (Standard: einsatzleiter_restore_test). Siehe Runbook, Abschnitt "Restore-Probe".
ExecStart=/home/clp-einsatz/htdocs/einsatzleiter/.venv/bin/python -m app.cli restore-test

[Install]
WantedBy=multi-user.target
